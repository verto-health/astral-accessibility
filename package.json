{
  "name": "astral-accessibility",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve astral-accessibility",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "cypress": "cypress open",
    "build:lib": "ng build astral-accessibility --output-hashing=none && cp dist/astral-accessibility-angular-output/browser/main.js dist/astral-accessibility-angular-output/main.js",
    "build:lib:dev": "ng build astral-accessibility --watch --configuration=development",
    "start:demo-server": "lite-server -c projects/demo/lite-server-config.json",
    "start:demo": "lite-server -c projects/demo/lite-server-config.json",
    "start:test-server": "npm-run-all build:lib start:demo-server",
    "format": "prettier --write \"projects/**/*.{ts,html,scss,json}\" \"*.json\""
  },
  "private": true,
  "resolutions": {
    "caniuse-lite": "^1.0.30001799"
  },
  "dependencies": {
    "@angular/animations": "^20.3.25",
    "@angular/common": "^20.3.25",
    "@angular/compiler": "^20.3.25",
    "@angular/core": "^20.3.25",
    "@angular/elements": "20.3.25",
    "@angular/forms": "^20.3.25",
    "@angular/platform-browser": "^20.3.25",
    "@angular/platform-browser-dynamic": "^20.3.25",
    "@angular/router": "^20.3.25",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.30",
    "@angular/cli": "~20.3.30",
    "@angular/compiler-cli": "^20.3.25",
    "@babel/helper-remap-async-to-generator": "^7.18.9",
    "@types/jasmine": "~4.0.0",
    "@types/node": "22",
    "bootstrap": "^5.3.1",
    "browserslist": "^4.28.6",
    "caniuse-lite": "^1.0.30001799",
    "cypress": "^12.17.4",
    "jasmine-core": "~4.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "lite-server": "^2.6.1",
    "ng-packagr": "20.3.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "primeicons": "^6.0.1",
    "typescript": "~5.8.3"
  }
}
